# Docker Compose project
COMPOSE_PROJECT_NAME=eshop

# Local development ports
API_GATEWAY_HTTP_PORT=5080
REACT_FRONTEND_HTTP_PORT=5173

# Frontend local configuration
# Empty value means same-origin API calls from the browser.
VITE_API_BASE_URL=

# Used by the Vite dev server proxy.
# For local npm run dev outside Docker, use: http://localhost:5080
# For Docker Desktop frontend container, use: http://host.docker.internal:5080
VITE_DEV_PROXY_TARGET=http://host.docker.internal:5080

# Temporary local identity until Keycloak integration is implemented
VITE_DEVELOPMENT_CUSTOMER_ID=local-development-user

# Infrastructure ports
POSTGRES_PORT=5432
REDIS_PORT=6379
KEYCLOAK_HTTP_PORT=18080
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
ASPIRE_DASHBOARD_PORT=18888
ASPIRE_DASHBOARD_OTLP_GRPC_PORT=4317
ASPIRE_DASHBOARD_OTLP_HTTP_PORT=4318

# PostgreSQL defaults
POSTGRES_USER=eshop
POSTGRES_PASSWORD=eshop_password
POSTGRES_DEFAULT_DB=postgres

# Logical databases
CATALOG_DB=catalog_db
ORDERS_DB=orders_db
INVENTORY_DB=inventory_db
PAYMENTS_DB=payments_db
NOTIFICATIONS_DB=notifications_db
KEYCLOAK_DB=keycloak_db

# Redis defaults
REDIS_PORT=6379

# RabbitMQ defaults
RABBITMQ_DEFAULT_USER=eshop
RABBITMQ_DEFAULT_PASS=eshop_password

# Keycloak local admin defaults
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin_password

# Planned Keycloak realm
KEYCLOAK_REALM=eshop

# Aspire Dashboard local development
ASPIRE_DASHBOARD_UNSECURED_ALLOW_ANONYMOUS=true
