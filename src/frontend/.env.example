# Empty value means same-origin API calls.
VITE_API_BASE_URL=

# Used only by the Vite development server proxy.
VITE_DEV_PROXY_TARGET=http://localhost:5080

# Public OpenID Connect client configuration.
# These values are embedded in browser JavaScript and must not contain secrets.
VITE_KEYCLOAK_URL=http://localhost:18080
VITE_KEYCLOAK_REALM=eshop
VITE_KEYCLOAK_CLIENT_ID=eshop-frontend
