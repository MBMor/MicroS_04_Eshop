{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "OrdersDb": "Host=localhost;Port=5432;Database=orders_db;Username=eshop;Password=eshop_password"
  },
  "Services": {
    "BasketBaseUrl": "http://localhost:5082/"
  },
  "Orders": {
    "AllowDevelopmentCustomerHeader": true,
    "DevelopmentCustomerHeaderName": "X-Customer-Id"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "eshop",
    "Password": "eshop_password",
    "VirtualHost": "/",
    "ClientProvidedName": "orders-service",
    "RequestedHeartbeatSeconds": 30,
    "AutomaticRecoveryEnabled": true,
    "TopologyRecoveryEnabled": true
  },
  "Outbox": {
    "BatchSize": 20,
    "PollingInterval": "00:00:02",
    "ClaimTimeout": "00:02:00",
    "MaximumRetryCount": 10,
    "InitialRetryDelay": "00:00:05",
    "MaximumRetryDelay": "00:05:00",
    "PublishedRetention": "7.00:00:00",
    "CleanupInterval": "06:00:00",
    "CleanupBatchSize": 500
  }
}
