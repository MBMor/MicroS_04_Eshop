{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "NotificationsDb": "Host=localhost;Port=5432;Database=notifications_db;Username=eshop;Password=eshop_password"
  },
  "Notifications": {
    "AllowDevelopmentCustomerHeader": true,
    "DevelopmentCustomerHeaderName": "X-Customer-Id"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "eshop",
    "Password": "eshop_password",
    "VirtualHost": "/",
    "ClientProvidedName": "notifications-service",
    "RequestedHeartbeatSeconds": 30,
    "AutomaticRecoveryEnabled": true,
    "TopologyRecoveryEnabled": true,
    "ConsumerDeliveryLimit": 3
  },
  "Keycloak": {
    "Authority": "",
    "Audience": "eshop-api",
    "RequireHttpsMetadata": true
  }
}
